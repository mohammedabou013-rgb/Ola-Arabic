# ─── Google AdSense ────────────────────────────────────────────────────────────
# Copy this file to .env.local and fill in your values.
#
# HOW TO GET STARTED:
#   1. Sign up at https://adsense.google.com
#   2. Add your site and wait for approval (usually 1-3 days)
#   3. Copy your Publisher ID (ca-pub-XXXXXXXXXXXXXXXX) below
#   4. Create 5 ad units in AdSense → "By ad unit" → "Display ads"
#      Name them: home-top, home-inline, grade-top, practice-top, lesson-end
#   5. Copy each unit's slot ID below
#   6. Set VITE_ADS_ENABLED=true
#   7. Redeploy the app

# Enable / disable ads globally (set to "true" to go live)
VITE_ADS_ENABLED=false

# Your AdSense Publisher ID (format: ca-pub-XXXXXXXXXXXXXXXX)
VITE_ADSENSE_PUB_ID=ca-pub-XXXXXXXXXXXXXXXX

# Ad unit slot IDs (get these from your AdSense dashboard)
VITE_AD_SLOT_HOME_TOP=0000000001
VITE_AD_SLOT_HOME_INLINE=0000000002
VITE_AD_SLOT_GRADE_TOP=0000000003
VITE_AD_SLOT_PRACTICE_TOP=0000000004
VITE_AD_SLOT_LESSON_END=0000000005
